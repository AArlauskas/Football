LTU_POSTGRES_PASSWORD=change_ltu_database_password
MKD_POSTGRES_PASSWORD=change_mkd_database_password

# Email mailbox used by the backend to send match reminder emails.
# Create this mailbox in Hostinger Email, then put the real credentials in .env.
EMAIL_USERNAME=notifications@example.com
EMAIL_PASSWORD=change_mailbox_password

# Optional. These defaults match Hostinger SMTP over SSL.
HOSTINGER_MAIL_HOST=smtp.hostinger.com
HOSTINGER_MAIL_PORT=465
